# ──────────────────────────────────────────────
# MolClaw Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ─── Required ─────────────────────────────────

# OpenAI-compatible provider config (required for the agent inside containers)
# Default example: DP gateway serving Claude 4.5 Sonnet
OPENAI_COMPAT_BASE_URL=https://openapi.dp.tech/openapi/v1
OPENAI_COMPAT_API_KEY=your-api-key-here
OPENAI_COMPAT_MODEL=openapi/claude-4.5-sonnet

# Alternative naming is also supported:
# LLM_BASE_URL=...
# LLM_API_KEY=...
# LLM_MODEL=...
#
# For local gateways without auth, API key can be omitted.

# OpenRouter (optional alias mode, recommended for OpenRouter users)
# MODEL_PROVIDER=openrouter
# DEFAULT_MODEL_PROVIDER=openrouter
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# OPENROUTER_MODELS=openai/gpt-4.1-mini,anthropic/claude-3.7-sonnet
# Optional aliases also accepted:
# OPENAI_COMPATIBLE_API_KEY=...
# OPENAI_COMPATIBLE_BASE_URL=...
# OPENAI_COMPATIBLE_MODEL=...
# OPENAI_COMPATIBLE_MODELS=model-a,model-b

# Proxy (optional, useful when container network must go through local proxy)
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# ALL_PROXY=http://127.0.0.1:7890

# Optional tuning
OPENAI_COMPAT_MAX_TOKENS=4096
OPENAI_COMPAT_TEMPERATURE=0.2
# OPENAI_COMPAT_THINKING_TYPE=enabled

# Dashboard (optional)
# DASHBOARD_ENABLED=true
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8787
# DASHBOARD_TOKEN=change-me

# ─── WhatsApp ─────────────────────────────────

# WhatsApp uses QR code authentication via Baileys.
# No credentials needed here — run `npm start` and scan the QR code
# with your WhatsApp app. Auth state is persisted in store/auth/.

# Set to false to skip WhatsApp entirely (Discord-only mode).
# WHATSAPP_ENABLED=false

# ─── Discord (Optional) ────────────────────────

# Discord bot token (from Discord Developer Portal)
# DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Optional: inbound attachment handling limits (Discord -> group workspace)
# Attachments are saved under groups/<group>/inbox/discord/<YYYY-MM-DD>/
# DISCORD_ATTACHMENT_MAX_BYTES=31457280
# DISCORD_ATTACHMENT_TIMEOUT_MS=15000

# Optional: inline image payload limits when sending user images to LLM
# If a user message contains [Image] ... saved=/workspace/group/... it will be
# converted to OpenAI-compatible image_url content parts (data URLs).
# Optional explicit capability override:
# OPENAI_COMPAT_MULTIMODAL=true   # force enable image input
# OPENAI_COMPAT_MULTIMODAL=false  # force disable and auto-notify user
# OPENAI_COMPAT_INLINE_IMAGE_MAX_BYTES=5242880
# OPENAI_COMPAT_INLINE_IMAGE_MAX_COUNT=3
